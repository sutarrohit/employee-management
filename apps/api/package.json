{
  "name": "@employee-management/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:reset": "tsx prisma/seed.ts --reset"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.2.4",
    "dotenv-expand": "^12.0.3",
    "hono": "^4.12.23",
    "hono-openapi": "^1.3.0",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stoker": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@employee-management/eslint-config": "*",
    "@employee-management/typescript-config": "*",
    "@types/node": "^20.19.41",
    "@vitest/coverage-v8": "^4.1.7",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
